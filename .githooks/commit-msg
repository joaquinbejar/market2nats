#!/bin/sh
#
# commit-msg hook: reject commit messages containing AI co-author attribution.
# Install: git config core.hooksPath .githooks
#

if grep -qiE 'co-authored-by:.*claude|co-authored-by:.*anthropic|generated with.*claude' "$1"; then
  echo "ERROR: Commit message contains AI co-author attribution."
  echo "Remove the Co-Authored-By trailer and retry."
  exit 1
fi
